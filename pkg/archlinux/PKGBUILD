# Maintainer: Kamil 'Novik' Nowicki <noviktech.com>
# Website: http://noviktech.com
# Repository: https://github.com/novik133/NovaBluetooth

pkgname=nova-bluetooth
pkgver=0.1.0
pkgrel=1
pkgdesc="Modern Bluetooth indicator for the XFCE4 panel"
arch=('x86_64' 'aarch64')
url="https://github.com/novik133/NovaBluetooth"
license=('GPL-2.0-or-later')
depends=('gtk3' 'glib2' 'xfce4-panel' 'libxfce4ui' 'xfconf' 'bluez')
makedepends=('meson' 'vala' 'pkg-config')
source=("$pkgname-$pkgver.tar.gz::$url/archive/v$pkgver.tar.gz")
sha256sums=('SKIP')

build() {
    cd "NovaBluetooth-$pkgver"
    meson setup build --prefix=/usr
    meson compile -C build
}

package() {
    cd "NovaBluetooth-$pkgver"
    DESTDIR="$pkgdir" meson install -C build
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
    install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
    install -Dm644 CHANGELOG.md "$pkgdir/usr/share/doc/$pkgname/CHANGELOG.md"
}
